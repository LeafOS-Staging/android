<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <remote name="lineage"
          fetch="https://github.com"
          revision="lineage-22.2"
          review="review.lineageos.org" />

  <!-- SDK -->
  <project path="device/lineage/sepolicy" name="LineageOS/android_device_lineage_sepolicy" remote="lineage" />
  <project path="hardware/lineage/interfaces" name="LineageOS/android_hardware_lineage_interfaces" remote="lineage" />
  <project path="lineage-sdk" name="LineageOS/android_lineage-sdk" remote="lineage" />

  <!-- Apps -->
  <project path="packages/apps/Aperture"  name="LineageOS/android_packages_apps_Aperture" remote="lineage" />
  <remove-project path="packages/apps/Camera2"/>
  <project path="packages/apps/Camera2" name="LineageOS/android_packages_apps_Camera2" remote="lineage" />
  <remove-project path="packages/apps/DeskClock"/>
  <project path="packages/apps/DeskClock"  name="LineageOS/android_packages_apps_DeskClock" remote="lineage" />
  <remove-project path="packages/apps/Dialer"/>
  <project path="packages/apps/Dialer"  name="LineageOS/android_packages_apps_Dialer" remote="lineage" />
  <remove-project path="packages/apps/Gallery2"/>
  <project path="packages/apps/Gallery2" name="LineageOS/android_packages_apps_Gallery2" remote="lineage" />
  <project path="packages/apps/Glimpse"  name="LineageOS/android_packages_apps_Glimpse" remote="lineage" />
  <remove-project path="packages/apps/Messaging"/>
  <project path="packages/apps/Messaging"  name="LineageOS/android_packages_apps_Messaging" remote="lineage" />
  <project path="packages/apps/SimpleDeviceConfig" name="LineageOS/android_packages_apps_SimpleDeviceConfig" remote="lineage" />
  <remove-project path="packages/inputmethods/LatinIME"/>
  <project path="packages/inputmethods/LatinIME"  name="LineageOS/android_packages_inputmethods_LatinIME" remote="lineage" />
  <project path="packages/resources/devicesettings" name="LineageOS/android_packages_resources_devicesettings" remote="lineage" />

  <!-- Extraction Tools -->
  <project path="tools/extract-utils" name="LineageOS/android_tools_extract-utils" remote="lineage" />
  <project path="prebuilts/tools-lineage" name="LineageOS/android_prebuilts_tools-lineage" remote="lineage" />
  <project path="prebuilts/extract-tools" name="LineageOS/android_prebuilts_extract-tools" remote="lineage" />
</manifest>
